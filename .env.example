# Pika shared env reconstruction template
# This file is a cross-repo aid only.
# Keys below are inferred from repo structure, backend launch notes, and current dev/preview needs.
# Any value marked VERIFY_ON_FIRST_RUN must be confirmed in the owning app before use.

# ------------------------------------------------------------------------------
# Shared / documentation-level values
# ------------------------------------------------------------------------------

NODE_ENV=development

# Canonical local ports for this phase are inferred, not confirmed.
FRONTEND_PORT=5173
BACKEND_PORT=3001

# Public frontend origin used for local browser access.
FRONTEND_ORIGIN=http://localhost:5173

# Backend base URL for local API access.
BACKEND_ORIGIN=http://localhost:3001

# Live backend baseline for this phase.
API_BASE_URL=http://localhost:3001
API_BASE_PATH=/api/v1
API_ROOMS_PATH=/api/v1/rooms

# Preview / deploy documentation placeholders.
PREVIEW_FRONTEND_PATH=frontend
PREVIEW_BACKEND_URL=VERIFY_ON_FIRST_RUN

# Guest-capable session header used by backend requests.
SESSION_HEADER_NAME=x-session-id

# ------------------------------------------------------------------------------
# Frontend app env candidates
# Place in frontend/.env or frontend/.env.local — VERIFY_ON_FIRST_RUN
# ------------------------------------------------------------------------------

VITE_APP_NAME=Pika
VITE_APP_ENV=development
VITE_API_URL=http://localhost:3001
VITE_API_BASE_URL=http://localhost:3001
VITE_API_BASE_PATH=/api/v1
VITE_ROOMS_API_PATH=/api/v1/rooms
VITE_SESSION_HEADER_NAME=x-session-id
VITE_ENABLE_AUTH=false
VITE_AUTH_PROVIDER=VERIFY_ON_FIRST_RUN

# Fallback names if the frontend code uses alternate conventions.
NEXT_PUBLIC_API_BASE_URL=VERIFY_ON_FIRST_RUN
NEXT_PUBLIC_API_BASE_PATH=VERIFY_ON_FIRST_RUN

# ------------------------------------------------------------------------------
# Backend app env candidates
# Place in backend/.env — VERIFY_ON_FIRST_RUN
# ------------------------------------------------------------------------------

PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# API and CORS candidates aligned to the live backend baseline.
API_PREFIX=/api/v1
API_VERSION=v1
CORS_ORIGIN=http://localhost:5173

# Guest session handling.
SESSION_HEADER_NAME=x-session-id
SESSION_SECRET=VERIFY_ON_FIRST_RUN

# Optional JSON-file persistence.
PERSISTENCE_MODE=memory
ROOMS_PERSISTENCE_MODE=VERIFY_ON_FIRST_RUN
JSON_STORAGE_ENABLED=false
JSON_STORAGE_FILE=VERIFY_ON_FIRST_RUN
DATA_FILE=VERIFY_ON_FIRST_RUN
DATA_DIR=VERIFY_ON_FIRST_RUN
STORAGE_DRIVER=VERIFY_ON_FIRST_RUN

# Auth remains a non-blocking integration stream for the guest-first slice.
AUTH_SECRET=VERIFY_ON_FIRST_RUN
AUTH_BASE_URL=VERIFY_ON_FIRST_RUN
AUTH_PROVIDER=VERIFY_ON_FIRST_RUN

# External service placeholders.
DATABASE_URL=VERIFY_ON_FIRST_RUN
REDIS_URL=VERIFY_ON_FIRST_RUN

# ------------------------------------------------------------------------------
# Contract/documentation placeholders
# ------------------------------------------------------------------------------

CONTRACT_PATH=workspace/packages/contracts/pika-vertical-slice.json
CONTRACT_AUTHORITY=backend