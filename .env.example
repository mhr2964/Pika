# Shared local development template for Pika
# Copy to .env and adjust for your machine/provider choices.

NODE_ENV=development

# Backend runtime
HOST=0.0.0.0
PORT=3001

# Frontend runtime
FRONTEND_PORT=5173
FRONTEND_ORIGIN=http://localhost:5173

# API wiring
API_BASE_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:5173

# Optional app-facing public API URL convention
VITE_API_BASE_URL=http://localhost:3001

# Persistence / session placeholders
# Fill these only if the active backend implementation requires them.
SESSION_SECRET=change-me
DATABASE_URL=

# Deployment placeholders
VERCEL_PROJECT_NAME=
VERCEL_TEAM_ID=