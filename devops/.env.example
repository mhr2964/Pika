# Pika Sprint 1 environment template
# Intended root destination: `workspace/.env.example`
# Source of truth while devops is path-scoped: `workspace/devops/.env.example`

# app identity
NODE_ENV=development
APP_NAME=Pika

# ports
FRONTEND_PORT=3000
BACKEND_PORT=4000
API_PORT=4000
WS_PORT=4001

# network / cors
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# frontend public env compatibility
VITE_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# gameplay defaults
ROOM_CODE_LENGTH=4

# infra placeholders
DATABASE_URL=
REDIS_URL=redis://localhost:6379

# secrets
SESSION_SECRET=change-me
JWT_SECRET=change-me

# observability
LOG_LEVEL=debug