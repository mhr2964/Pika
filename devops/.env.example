# Pika Sprint 1 environment template
# Intended destination after platform integration: `workspace/.env.example`
# Current source-of-truth path: `workspace/devops/.env.example`

# app identity
NODE_ENV=development
APP_NAME=Pika

# canonical local ports
FRONTEND_PORT=3000
BACKEND_PORT=4000
API_PORT=4000
WS_PORT=4001
REDIS_PORT=6379

# backend network / cors
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# frontend public API base compatibility
VITE_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# gameplay defaults
ROOM_CODE_LENGTH=4

# data / infra
DATABASE_URL=
REDIS_URL=redis://localhost:6379

# legacy backend compatibility
PORT=4000

# secrets
SESSION_SECRET=change-me
JWT_SECRET=change-me

# observability
LOG_LEVEL=debug