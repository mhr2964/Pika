{
  "name": "pika-workspace",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/frontend",
    "apps/backend",
    "packages/contracts"
  ],
  "scripts": {
    "dev": "npm run dev:frontend & npm run dev:backend",
    "dev:frontend": "npm --prefix apps/frontend run dev",
    "dev:backend": "npm --prefix apps/backend run dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "npm --prefix apps/frontend run build",
    "build:backend": "npm --prefix apps/backend run build",
    "check": "npm run check:frontend && npm run check:backend && npm run contracts:check",
    "check:frontend": "npm --prefix apps/frontend run check",
    "check:backend": "npm --prefix apps/backend run check",
    "contracts:check": "npm --prefix packages/contracts run check"
  }
}