{
  "name": "pika-vertical-slice",
  "version": "1.0.0",
  "authority": "backend",
  "canonicalRoots": [
    "frontend",
    "backend",
    "packages/contracts",
    "docs"
  ],
  "flow": [
    "create_room",
    "add_options",
    "generate_matchup",
    "submit_selection",
    "compute_results",
    "show_results"
  ],
  "ownership": {
    "ownerUserId": "string | null",
    "ownerSessionId": "string | null"
  },
  "entities": {
    "Room": {
      "id": "string",
      "slug": "string",
      "title": "string",
      "status": "draft | active | complete",
      "ownerUserId": "string | null",
      "ownerSessionId": "string | null",
      "createdAt": "string",
      "updatedAt": "string"
    },
    "Option": {
      "id": "string",
      "roomId": "string",
      "label": "string",
      "description": "string | null",
      "createdAt": "string"
    },
    "Matchup": {
      "id": "string",
      "roomId": "string",
      "leftOptionId": "string",
      "rightOptionId": "string",
      "round": "number",
      "status": "pending | answered"
    },
    "Selection": {
      "id": "string",
      "roomId": "string",
      "matchupId": "string",
      "chosenOptionId": "string",
      "ownerUserId": "string | null",
      "ownerSessionId": "string | null",
      "createdAt": "string"
    },
    "Result": {
      "roomId": "string",
      "winnerOptionId": "string | null",
      "rankedOptionIds": "string[]",
      "totalSelections": "number",
      "completedAt": "string | null"
    }
  },
  "routes": [
    {
      "method": "POST",
      "path": "/api/rooms"
    },
    {
      "method": "POST",
      "path": "/api/rooms/:roomId/options"
    },
    {
      "method": "POST",
      "path": "/api/rooms/:roomId/matchups/generate"
    },
    {
      "method": "POST",
      "path": "/api/rooms/:roomId/selections"
    },
    {
      "method": "POST",
      "path": "/api/rooms/:roomId/results/compute"
    },
    {
      "method": "GET",
      "path": "/api/rooms/:roomId/results"
    }
  ]
}